{
    "name": "redhn",
    "version": "1.0.0",
    "description": "RedHN: A Reddit-style extension for Hacker News",
    "homepage": "https://github.com/fanjin-z/RedHN#readme",
    "bugs": {
        "url": "https://github.com/fanjin-z/RedHN/issues"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/fanjin-z/RedHN.git"
    },
    "license": "MIT",
    "author": "",
    "type": "module",
    "scripts": {
        "dev": "wxt",
        "dev:firefox": "wxt -b firefox",
        "build": "wxt build",
        "build:firefox": "wxt build -b firefox",
        "build:safari": "wxt build -b safari --mv3",
        "zip": "wxt zip",
        "zip:firefox": "wxt zip -b firefox",
        "zip:safari": "wxt zip -b safari --mv3",
        "package:safari": "scripts/package-safari.sh",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "format:all": "prettier --write .",
        "format:cached": "prettier $(git diff --cached --name-only --diff-filter=ACMR | sed 's| |\\ |g') --write --ignore-unknown",
        "typecheck": "tsc --noEmit",
        "test": "vitest run",
        "test:watch": "vitest",
        "postinstall": "wxt prepare",
        "prepare": "husky"
    },
    "devDependencies": {
        "@eslint/js": "^9.27.0",
        "@types/node": "^22.15.17",
        "@types/react": "^19.2.15",
        "@types/react-dom": "^19.2.3",
        "eslint": "^9.27.0",
        "eslint-config-prettier": "^10.1.8",
        "globals": "^15.15.0",
        "husky": "^9.1.7",
        "linkedom": "^0.18.12",
        "prettier": "^3.8.3",
        "typescript": "^5.8.3",
        "typescript-eslint": "^8.33.0",
        "vitest": "^4.1.5",
        "wxt": "^0.20.26"
    },
    "dependencies": {
        "@phosphor-icons/react": "^2.1.10",
        "react": "^19.2.6",
        "react-dom": "^19.2.6"
    }
}
